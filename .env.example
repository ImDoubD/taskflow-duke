# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=taskflow
DB_PASSWORD=taskflow
DB_NAME=taskflow
DB_SSLMODE=disable

# API Server
PORT=8080

# JWT — generate a strong random secret for production
# e.g.: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_secret_in_production

# Seed test data on startup (set to false after first run if desired)
RUN_SEED=true
